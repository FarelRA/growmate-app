{
  "name": "growmate-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --host",
    "convex:dev": "convex dev",
    "postinstall": "nuxt prepare",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "nuxt preview --host",
    "build-only": "nuxt build",
    "type-check": "nuxt typecheck",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli app/ convex/",
    "check": "run-s type-check lint build-only"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.91",
    "@convex-vue/core": "^0.0.4",
    "convex": "^1.35.1",
    "nuxt": "^4.4.2",
    "openai": "^6.34.0",
    "vue": "^3.5.32",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.2.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.57.0",
    "prettier": "3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.3",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
